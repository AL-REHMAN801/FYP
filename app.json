{
  "expo": {
    "name": "rapid-assist",
    "slug": "rapid-assist",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/roadsite-icon.png",
      "userInterfaceStyle": "light",
    "splash": {
      "image": "./src/assets/images/roadsite-icon.png",
      "resizeMode": "contain",
        "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/images/roadsite-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./src/assets/images/roadsite-icon.png"
    }
  }
}
